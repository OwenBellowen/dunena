    "test": "bun test",
    "check": "bunx tsc --noEmit -p tsconfig.json"
  },
  "optionalDependencies": {
    "mongodb": "^6.3.0",
    "ioredis": "^5.3.0",
    "@aws-sdk/client-s3": "^3.500.0"
  }
