{
  "name": "@dunena/platform",
  "version": "0.3.1",
  "private": true,
  "type": "module",
  "main": "src/runtime.ts",
  "exports": {
    ".": "./src/runtime.ts",
    "./server": "./src/server/app.ts",
    "./types": "./src/types/index.ts",
    "./cli": "./src/cli/index.ts"
  },
  "scripts": {
    "start": "bun run src/index.ts",
