{
  "name": "@dunena/server",
  "version": "0.2.1",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "bun run --watch src/index.ts",
    "start": "bun run src/index.ts",
    "build": "bun build src/index.ts --target=bun --outfile dist/server.js",
    "build:compile": "bun build src/index.ts --compile --outfile dist/dunena-server",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@dunena/platform": "workspace:*"
  }
}
