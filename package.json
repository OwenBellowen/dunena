{
  "name": "dunena-monorepo",
  "version": "0.2.1",
  "description": "High-performance cache engine with a Zig core and Bun/TypeScript control layer",
  "private": true,
  "type": "module",
  "homepage": "https://github.com/OwenBellowen/dunena",
  "repository": {
    "type": "git",
    "url": "https://github.com/OwenBellowen/dunena.git"
  },
  "keywords": ["cache", "zig", "bun", "ffi", "lru", "bloom-filter", "sqlite"],
  "bin": {
    "dunena": "./bin/dunena.ts"
  },
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "scripts": {
    "build:zig": "cd zig && zig build -Doptimize=ReleaseSafe",
    "build:zig:fast": "cd zig && zig build -Doptimize=ReleaseFast",
    "build:zig:debug": "cd zig && zig build",
    "build": "bun run build:zig",
    "dev": "bun run --cwd apps/server dev",
    "start": "bun run --cwd apps/server start",
    "cli": "bun run --cwd apps/cli cli",
    "doctor": "bun run bin/dunena.ts doctor",
    "test": "bun run --cwd packages/platform test",
    "test:zig": "cd zig && zig build test",
    "test:all": "bun run test:zig && bun run test",
    "check": "bun run --cwd packages/platform check",
    "build:server": "bun run --cwd apps/server build",
    "build:cli": "bun run --cwd apps/cli build",
    "build:apps": "bun run build:server && bun run build:cli",
    "release:prepare": "bun run build:zig && bun run check && bun run test:all && bun run build:apps",
    "docker:build": "docker build -f apps/server/Dockerfile -t dunena/server:local .",
    "docker:up": "docker compose -f deploy/docker-compose.yml up -d",
    "docker:down": "docker compose -f deploy/docker-compose.yml down"
  },
  "devDependencies": {
    "@types/bun": "latest",
    "typescript": "^5.7.3"
  }
}
