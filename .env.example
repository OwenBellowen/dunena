# Global app defaults
DUNENA_HOST=0.0.0.0
DUNENA_PORT=3000
DUNENA_LOG_LEVEL=info
DUNENA_LOG_FORMAT=json
DUNENA_MAX_ENTRIES=250000
DUNENA_DEFAULT_TTL=300000
DUNENA_BLOOM_FILTER=true
DUNENA_BLOOM_SIZE=1000000
DUNENA_BLOOM_HASHES=7
DUNENA_DB_PATH=/var/lib/dunena/dunena.sqlite
DUNENA_RATE_MAX=2000
DUNENA_RATE_WINDOW=60000
DUNENA_CORS_ORIGINS=*
DUNENA_AUTH_TOKEN=replace-me

# Persistence
DUNENA_PERSIST=false
DUNENA_PERSIST_PATH=./data/dunena-snapshot.json
DUNENA_PERSIST_INTERVAL=300000
DUNENA_PERSIST_ON_SHUTDOWN=true

# Redis Protocol Adapter
DUNENA_REDIS_ENABLED=false
DUNENA_REDIS_PORT=6379
DUNENA_REDIS_HOST=0.0.0.0

# OpenTelemetry
DUNENA_OTEL_ENABLED=false
DUNENA_OTEL_ENDPOINT=http://localhost:4318
DUNENA_OTEL_SERVICE_NAME=dunena

# GraphQL (always available at /graphql when graphql-yoga is installed)

# Clustering / High Availability
DUNENA_CLUSTER_ENABLED=false
DUNENA_CLUSTER_NODE_ID=node-1
DUNENA_CLUSTER_SEEDS=
DUNENA_CLUSTER_HEARTBEAT_MS=2000
DUNENA_CLUSTER_SUSPECT_TIMEOUT_MS=6000
DUNENA_CLUSTER_DEAD_TIMEOUT_MS=15000
DUNENA_CLUSTER_ELECTION_TIMEOUT_MS=5000
DUNENA_CLUSTER_PRIORITY=100
DUNENA_CLUSTER_LOCAL_READS=true
