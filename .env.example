# Global app defaults
DUNENA_HOST=0.0.0.0
DUNENA_PORT=3000
DUNENA_LOG_LEVEL=info
DUNENA_LOG_FORMAT=json
DUNENA_MAX_ENTRIES=250000
DUNENA_DEFAULT_TTL=300000
DUNENA_BLOOM_FILTER=true
DUNENA_BLOOM_SIZE=1000000
DUNENA_BLOOM_HASHES=7
DUNENA_DB_PATH=/var/lib/dunena/dunena.sqlite
DUNENA_RATE_MAX=2000
DUNENA_RATE_WINDOW=60000
DUNENA_CORS_ORIGINS=*
DUNENA_AUTH_TOKEN=replace-me
